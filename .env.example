# ─────────────────────────────────────────────────────────────────
#  BBB Manager — Variables d'environnement
#  Copier ce fichier vers .env et remplir les valeurs
# ─────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3456

# ─── NextAuth / SSO ──────────────────────────────────────────────
# URL publique de l'application (pour les callbacks OAuth)
NEXTAUTH_URL=https://votre-domaine.example.com
AUTH_URL=https://votre-domaine.example.com
AUTH_TRUST_HOST=true

# Secret pour signer les sessions NextAuth
# Générer avec : openssl rand -base64 32
AUTH_SECRET=changeme-generer-avec-openssl

# ─── PostgreSQL ──────────────────────────────────────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/bbb_manager

# ─── Redis (rate limiting + lock cron auto-sync) ─────────────────
REDIS_URL=redis://:password@127.0.0.1:6379/1

# ─── Cron auto-sync ──────────────────────────────────────────────
# Active la synchronisation automatique toutes les heures (0 * * * *)
# Désactiver avec "false" (typique pour les environnements dev)
SYNC_AUTO_ENABLED=true

# ─── Keycloak OIDC ───────────────────────────────────────────────
KEYCLOAK_ISSUER=https://keycloak.example.com/realms/VOTRE_REALM
KEYCLOAK_CLIENT_ID=votre-client-id
KEYCLOAK_CLIENT_SECRET=votre-client-secret

# Direction Keycloak autorisée (filtre d'accès à l'application)
ALLOWED_DIRECTION=DITSI

# ─── Chiffrement des secrets BBB ─────────────────────────────────
# Clé AES-256 (64 caractères hex = 32 bytes)
# Générer avec : openssl rand -hex 32
# ATTENTION : si cette clé change, tous les secrets BBB en base
# deviendront illisibles. Conserver précieusement.
ENCRYPTION_KEY=changeme-generer-avec-openssl-rand-hex-32

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  auditeur
}

model User {
  id                String    @id @default(uuid())
  kcSub             String    @unique @map("kc_sub")
  email             String
  preferredUsername String    @map("preferred_username")
  givenName         String?   @map("given_name")
  familyName        String?   @map("family_name")
  fullName          String?   @map("full_name")
  direction         String
  role              UserRole  @default(auditeur)
  isActive          Boolean   @default(true) @map("is_active")
  lastLogin         DateTime? @map("last_login")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  rebuildJobs RebuildJob[]

  @@index([kcSub])
  @@index([direction])
  @@map("users")
}

model MoodlePlatform {
  id                  String    @id @default(uuid())
  name                String
  url                 String
  tokenEnc            String    @map("token_enc")
  serviceName         String?   @map("service_name")
  wsUsername          String?   @map("ws_username")
  siteName            String?   @map("site_name")
  // Identifiant unique de la plateforme cote BBB (metadata bbb-origin-server-name)
  // Sert a filtrer les recordings d'une plateforme dans la recherche Moodle.
  bbbOriginServerName String?   @map("bbb_origin_server_name")
  lastCheckAt         DateTime? @map("last_check_at")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("moodle_platforms")
}

model BbbServer {
  id           String    @id @default(uuid())
  name         String
  url          String
  secretEnc    String    @map("secret_enc")
  // URL de base pour acceder au dossier raw via Nginx (lecture des events.xml)
  // Format : https://serveur/bbbmanager/  (le recordId sera concatene apres)
  rawIndexUrl     String?  @map("raw_index_url")
  // Basic Auth pour l'index raw, format "user:pass" chiffre AES-256-GCM
  rawIndexAuthEnc String?  @map("raw_index_auth_enc")
  sshHost      String?   @map("ssh_host")
  sshPort      Int       @default(22) @map("ssh_port")
  sshUser      String?   @map("ssh_user")
  sshKeyEnc    String?   @map("ssh_key_enc")
  isActive     Boolean   @default(true) @map("is_active")
  lastSyncAt   DateTime? @map("last_sync_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  recordings    Recording[]
  rebuildJobs   RebuildJob[]
  rawDiscoveries RawDiscovery[]

  @@map("bbb_servers")
}

model Recording {
  id           String    @id @default(uuid())
  recordId     String    @unique @map("record_id")
  meetingId    String    @map("meeting_id")
  name         String
  durationSec  Int       @map("duration_sec")
  published    Boolean   @default(false)
  state        String
  startTime    DateTime  @map("start_time")
  endTime      DateTime? @map("end_time")
  playbackUrl  String?   @map("playback_url")
  rawData      Json?     @map("raw_data")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  server       BbbServer  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId     String     @map("server_id")
  rebuildJobs  RebuildJob[]

  @@index([serverId])
  @@index([published])
  @@index([state])
  @@index([startTime])
  @@index([serverId, state])
  @@map("recordings")
}

// Index des recordings detectes en raw via l'autoindex Nginx + events.xml.
// Un cron rafraichit cette table toutes les 4h, en respectant une fenetre de scan
// (RAW_SCAN_WINDOW_DAYS) afin d'eviter de fetcher tout le disque.
// Les entrees dont le dossier disparait du autoindex sont automatiquement purgees.
model RawDiscovery {
  id                String   @id @default(uuid())
  recordId          String   @map("record_id")
  serverId          String   @map("server_id")
  // metriques extraites de events.xml
  startTimeMs       BigInt?  @map("start_time_ms")
  durationSec       Int?     @map("duration_sec")
  participantCount  Int      @default(0) @map("participant_count")
  chatMessageCount  Int      @default(0) @map("chat_message_count")
  hasScreenShare    Boolean  @default(false) @map("has_screen_share")
  hasWebcam         Boolean  @default(false) @map("has_webcam")
  // metadata de events.xml utiles pour filtrer par plateforme Moodle
  bbbOriginServerName String? @map("bbb_origin_server_name")
  bbbContextName    String?  @map("bbb_context_name")
  bbbContextLabel   String?  @map("bbb_context_label")
  // critere derive : >= MIN_DURATION_SEC ET >= MIN_PARTICIPANTS
  isRebuildable     Boolean  @default(false) @map("is_rebuildable")
  // cross-check au moment du scan : la recording est elle deja publiee en base ?
  publishedInDb     Boolean  @default(false) @map("published_in_db")
  // timestamp du dossier dans l'autoindex (pour scan incremental)
  rawMtimeMs        BigInt?  @map("raw_mtime_ms")
  scannedAt         DateTime @default(now()) @map("scanned_at")

  server BbbServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([recordId, serverId])
  @@index([isRebuildable, publishedInDb])
  @@index([startTimeMs])
  @@index([bbbOriginServerName])
  @@map("raw_discoveries")
}

model RebuildJob {
  id          String    @id @default(uuid())
  status      String    @default("pending")
  startedAt   DateTime? @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  errorMsg    String?   @map("error_msg")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  recordingId String    @map("recording_id")
  server      BbbServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId    String    @map("server_id")
  user        User      @relation(fields: [userId], references: [id])
  userId      String    @map("user_id")

  @@index([recordingId])
  @@index([status])
  @@index([recordingId, status])
  @@map("rebuild_jobs")
}
